{
  "name": "distribuidora",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node app.js",
    "seed": "node seed.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder build --win",
    "test": "jest",
    "db:clear": "node clean-db.js"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "qrcode-terminal": "^0.12.0",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
  "build": {
    "appId": "com.distribuidora.app",
    "productName": "Distribuidora",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "frontend/assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Distribuidora",
      "include": "build/installer.nsh"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules/electron",
      "!node_modules/electron-builder",
      "!.git",
      "!database.sqlite",
      "!.wwebjs_auth/**/*",
      "!.wwebjs_cache/**/*",
      "!session-distribuidora-session/**/*",
      "!.mds/**/*",
      "!**/*.md",
      "!docs/**/*",
      "!scratch/**/*"
    ],
    "asar": true
  }
}
